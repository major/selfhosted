{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Chicago",
  "enabledManagers": ["flux", "helm-values", "github-actions"],
  "flux": {
    "managerFilePatterns": [
      "/(?:^|/)gotk-components\\.ya?ml$/",
      "/^clusters/.+\\.ya?ml$/",
      "/^apps/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": ["/^apps/.+\\.ya?ml$/"]
  },
  "platformAutomerge": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "branchConcurrentLimit": 0,
  "packageRules": [
    {
      "description": "Auto-merge minor and patch updates after stability window",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Auto-merge container digest updates",
      "matchUpdateTypes": ["digest"],
      "automerge": true
    },
    {
      "description": "Auto-merge GitHub Actions patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Require manual review for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    }
  ]
}
